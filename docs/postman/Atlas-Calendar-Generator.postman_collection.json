    "name": "Atlas Calendar Generator Control",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Ready-to-run requests for academics-calendar agent: Generate Calendar, Add Event, Holiday Mapping, Export Calendar."
  },
  "item": [
    {
      "name": "Generate Calendar",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"agent_id\": \"academics-calendar\",\n  \"action\": \"Generate Calendar\",\n  \"context\": \"{\\\"school_id\\\":\\\"{{school_id}}\\\",\\\"academic_year\\\":\\\"{{academic_year}}\\\",\\\"start_date\\\":\\\"{{start_date}}\\\",\\\"end_date\\\":\\\"{{end_date}}\\\",\\\"holidays\\\":[{\\\"name\\\":\\\"Independence Day\\\",\\\"date\\\":\\\"2026-08-15\\\"},{\\\"name\\\":\\\"Republic Day\\\",\\\"date\\\":\\\"2027-01-26\\\"}],\\\"exam_windows\\\":[{\\\"name\\\":\\\"Mid Sem\\\",\\\"start\\\":\\\"2026-11-12\\\",\\\"end\\\":\\\"2026-11-28\\\"},{\\\"name\\\":\\\"End Sem\\\",\\\"start\\\":\\\"2027-04-10\\\",\\\"end\\\":\\\"2027-04-26\\\"}]}\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/agent-exec/run",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "agent-exec",
            "run"
          ]
        },
        "description": "Creates semester calendar with teaching days and holiday adjustments."
      },
      "response": []
    },
